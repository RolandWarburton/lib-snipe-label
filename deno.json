{
  "name": "@wirecrop/snipeit-label",
  "license": "GPL-3.0-only",
  "version": "0.1.2",
  "description": "Browser library for generating encrypted asset labels for Snipe-IT.",
  "tasks": {
    "build-examples": "deno run -A ./scripts/build-examples.ts",
    "serve-examples": "deno run build-examples && deno run -A ./scripts/serve-examples.ts",
    "create-release": "deno run -A ./scripts/release.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "qrcode": "npm:qrcode@^1.5.4",
    "@types/qrcode": "npm:@types/qrcode@^1.5.5",
    "file-server": "jsr:@std/http@^1.0.14/file-server",
    "esbuild": "npm:esbuild@0.24.2",
    "esbuild-deno-loader": "jsr:@luca/esbuild-deno-loader@0.11.1"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext", "deno.ns"]
  },
  "exports": "./mod.ts"
}
